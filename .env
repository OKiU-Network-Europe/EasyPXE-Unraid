# ===== PXE server configuration =====
# Set these before starting the stack, then run ./setup.sh once.

# Static LAN IP of your Unraid server
UNRAID_IP=192.168.1.10

# Your LAN network address (NOT a range) - used for proxyDHCP
SUBNET=192.168.1.0

# Port for the HTTP server (80 is taken by the Unraid web UI)
HTTP_PORT=8080
